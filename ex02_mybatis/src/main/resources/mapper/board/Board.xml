<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.board.mapper.BoardMapper">
  <sql id="board">
    bno,
    title,
    content,
	writer,
	regdate,
	updatedate
  </sql>
  
  <!-- 전제조회 -->
  <select id="findAll">
    SELECT 
    <include refid="board"></include>
    FROM tbl_board
  </select>
  
  <!-- 단건조회 -->
  <select id="findById">
    SELECT 
    <include refid="board"></include>
    FROM tbl_board
    WHERE bno = #{id}
  </select>
  
  <!-- 등록 -->
  <insert id="insert">
  <selectKey keyProperty="bno" resultType="int" order="BEFORE">
    SELECT seq_board.nextval
    FROM dual
  </selectKey>
    INSERT INTO tbl_board(<include refid="board"></include>)
    VALUES(#{bno},
           #{title},
           #{content},
	       #{writer},
	       sysdate,
           sysdate)    
  </insert>
  
  <!-- 삭제 -->
  <delete id="delete">
  DELETE FROM tbl_board
  WHERE bno = #{bno}
  </delete>
</mapper>